groups:
- name: drm_alerts
  rules:

  - alert: NodeVideotronMati
    expr: probe_success{job="Real_Videotron"} == 0
    for: 1m
    labels:
      severity: critical
    annotations:
      summary: "🚨 DARURAT: {{ $labels.instance }} OFFLINE"
      description: "Perangkat {{ $labels.instance }} tidak merespons transmisi jaringan selama lebih dari 1 menit. Segera periksa infrastruktur fisik atau sumber daya listrik di lokasi operasional!"

  - alert: VideotronUptimeLow
    expr: avg_over_time(probe_success{job="Real_Videotron"}[1h]) * 100 < 80
    for: 5m
    labels:
      severity: warning
    annotations:
      summary: "⚠️ Uptime {{ $labels.instance }} di bawah 80%"
      description: "Uptime {{ $labels.instance }} hanya {{ $value | printf \"%.2f\" }}% dalam 1 jam terakhir."

  - alert: VideotronSlow
    expr: probe_duration_seconds{job="Real_Videotron"} > 3
    for: 2m
    labels:
      severity: warning
    annotations:
      summary: "🐢 Videotron {{ $labels.instance }} lambat"
      description: "Response time {{ $labels.instance }} melebihi 3 detik."
