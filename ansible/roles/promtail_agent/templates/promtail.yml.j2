
# Config di-generate otomatis oleh Ansible
# Device : {{ vtron_name }}
# Host   : {{ ansible_host }}

server:
  http_listen_port: 9080

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ monitoring_server_ip }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: docker
    static_configs:
      - targets:
          - localhost
        labels:
          job: docker
          host: {{ inventory_hostname }}
          vtron_name: "{{ vtron_name }}"
          __path__: /var/lib/docker/containers/*/*-json.log
